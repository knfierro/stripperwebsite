---
layout: layouts/base.njk
title: Premium Strippers in Scottsdale & Phoenix
description: Premium Strippers in Scottsdale & Phoenix for Bachelor Parties and Private Events
---

<style>
    :root { 
 --light-color:{{ home.lightColor }};
  --light-opacity: {{home.lightOpacity}};
  --dark-color: {{home.darkColor}};
  --accent-color:  {{home.accentColor}};
  --text-color:   {{home.textColor}};
  --muted-color:    {{home.mutedColor}};
  }
</style>

<main>
<section id="home" class="hero section">
<div class="container hero-cont">
        <div class="hero-text">
            <h1 class="hero-headline fade-up"><span class="location-text"> {{ home.locationName}} </span><br> {{ home.heroHeadline}} </h1>
            <p class="hero-subheadline fade-up"> {{ home.heroSubtitle | safe }} </p>
            <p class="fade-up hero-location">{{ home.serviceArea | safe }}</p>
            <a href="tel:+14804689801"><button class="hero-b buttons color-change fade-up hero-buttons"> {{ home.buttonCTA }}</button></a>
        
        </div>
</div>
</section>


<!-------------CTA SECTION------------------------>
    <section class="cta section">
     <div class="container">
        <div class="center-text-box">
            <p class="fade-up location-text cta-title opacity">No Disappointments</p>
            <p class=" fade-up location-text cta-title">Just Premium Experiences</p>
            <p class="fade-up cta-text">
                <h2 class="fade-up mg-btm-lg lg-text standard-l-h"> {{ home.introTitle | safe }} </h2>
         </div>
    </section>


<!--------------------SERVICES GRID ---------------------------------------------------->
    <section class="services">
        <div class="service-box">
            <div class="first-image"></div>
                <div class="service-text">
                    <h3 class="service-headline location-text"> {{home.featureTitleOne }} </h3>
                    <p>{{ home.featureOneDescription}} </p>

                </div>
        </div>

        <div class="service-box">
            <div class="second-image"></div>
            <div class="service-text">
                <h3 class="service-headline location-text">{{home.featureTitleTwo }}</h3>
                <p>{{ home.featureTwoDescription}}</p>
            
            </div>
        </div>

        <div class="service-box">
            <div class="third-image"></div>
            <div class="service-text">
                <h3 class="service-headline location-text">{{home.featureTitleThree }}</h3>
                <p>{{home.featureThreeDescription}}</p>
            </div>
        </div>
    </section>
<!-------------OFFERS SECTION------------------------>

<section class="section offers">
    <div class="container">
<h2 class="mg-btm-md lg-text">{{home.centerQuote }}</h2>

</div>
</section>

<!-------------ENVIRONMENTS SECTION------------------------>

<section class="environments"> 
    <h2 class="location-text mg-btm-lg">{{home.experienceTitle}}</h2>

   <div class="envo-bubbles">
<div class="envo-bubble is-active private"><h3> {{home.bubbleOne }}</h3></div>
<div class="envo-bubble is-active bachelor"><h3> {{home.bubbleTwo }}</h3></div>
<div class="envo-bubble is-active golf"><h3>{{home.bubbleThree }}</h3></div>
<div class="envo-bubble is-active vip"><h3>{{home.bubbleFour }}</h3></div>
<div class="envo-bubble is-active pool"><h3>{{home.bubbleFive }}</h3></div>
<div class="envo-bubble is-active military"><h3>{{home.bubbleSix}}</h3></div>
    </div>

    </div>
    </section>

<!-------------PRICING SECTION------------------------>
<section id="pricing-section" class="pricing section">
<div class="container">
  <h2 class="pricing-title fade-up location-text">Choose Your Package</h2>
  <h3 class="pricing-subtitle fade-up">We offer 100% Money-Back Guarantee if the women arrive and you aren't blown away</h3>
<div class="pricing-cards fade-up">
<div class="pricing-card">
    <div>
     <h3 class="location-text">{{home.packageOneTitle | safe}}</h3><br>
      <p class="pricing-description">{{home.packageOnePricing | safe}}</p>
      </div>
      <ul class="pricing-list">
           <li>{{home.packageOneFeature1}}</li>
            <li>{{home.packageOneFeature2}}</li>
            <li>{{home.packageOneFeature3}}</li>
      </ul>
      <a href="tel:+14804689801"><button class="hero-buttons">Book Now</button></a>


</div>
<div class="pricing-card">
    <div>
     <h3 class="location-text">{{home.packageTwoTitle | safe}}</h3><br>
      <p class="pricing-description">{{home.packageTwoPricing | safe}}</p>
      </div>
      <ul class="pricing-list">
        <li class="opacity">{{home.packageTwoFeature1}}</li>
        <li>{{home.packageTwoFeature2 | safe}}</li>
      </ul>
      <a href="tel:+14804689801"><button class="hero-buttons">Book Now</button></a>
</div>


<div class="pricing-card">
    <div>
     <h3 class="location-text">{{home.packageThreeTitle | safe}}</h3><br>
      <p class="pricing-description">{{home.packageThreePricing | safe}}</p>
      </div>
      <ul class="pricing-list">
         <li class="opacity">{{home.packageThreeFeature1}}</li>
         <li>{{home.packageThreeFeature2}}</li>
        <li>{{home.packageThreeFeature3}}</li>
      </ul>
      <a href="tel:+14804689801"><button class="hero-buttons">Book Now</button></a>
</div>
</div>
<div class="add-on">
    <h3 class="location-text">Optional Add-Ons:</h3><br>
    <div class="add-on-text mg-btm-lg">
        <div class="add-on-item">
            <img class="add-icon" src="assets/icons/icons8-party-64.png" alt="Party Toy Icon">
            <p class="add-description">Party Games</p>
         </div>
         <div class="add-on-item">
            <img class="add-icon" src="assets/icons/icons8-face-50.png" alt="Face Icon">
            <p class="add-description">Custom "Guest of Honor" Face Panties or Sign</p>
         </div>
         <div class="add-on-item">
            <img class="add-icon" src="assets/icons/icons8-glass-of-whiskey-50.png" alt="Alcohol Icon">
            <p class="add-description">Bartending Services</p>
         </div>

    </div>
</div>

<p class="fade-up text-padding">Need more time? Just ask and we'll accomadate you the best we can with flexible scheduling.
</p>
</section>

<!-------------PARTY RULES SECTION------------------------>
<section class="party section">
<div class="container">
<div class="party-rules">
    <div class="party-rule-text">
    <h3 class="location-text">Party Rules</h3><br>
    <h4 class="party-subtitle">We want eveyone to have fun, that means playing by a few rules:</h4>
      <li class="list">1. Treat the dancers with respect, each dancer sets their own boundaries prior to beginning their performance</li>
      <li class="list">2. We require a two-girl minimum for safety purposes</li>
      <li class="list">3. I.D. is required before booking for indentity verification</li>
      <li class="list">4. If boundaries are crossed, dancers will leave without a refund issued</li>
</div>
</div>
</div>
</section>

<!-------------PROCESS SECTION------------------------>

<section class="process section">
    <div class="container" id="process-section">
        <div class="process-container fade-up">
        <div class="process-card">
            <img class="bouncy-icon" src="assets/icons/icons8-ringer-volume-24.png" alt="Phone Icon">
            <h3 class="process-title location-text">Contact</h3>
            <p class="process-subtitle">Call {{home.phoneNumber}}</p>
            <p class="process-description">Call or Text us for more information regarding scheduling, availability and event details. We also accomodate custom requests.</p>
        </div>
      
        <div class="process-card">
            <img class="bouncy-icon" src="assets/icons/icons8-calendar-24.png" alt="Money Icon">
            <h3 class="process-title location-text">Book Event</h3>
            <p class="process-subtitle">Choose a Package</p>
            <p class="process-description">Once you've decided on your package we'll send you real photos of the girls available for your special night. A 20% non-refundable deposit for reach reservation is required.</p>
        </div>
         <!--GET icons from icons8.com, <a target="_blank" href="https://icons8.com/icon/81805/arrow-right">Arrow Right</a> icon by <a target="_blank" href="https://icons8.com">Icons8</a> Download png and add to assets-->
                
        <div class="process-card">
            <img class="bouncy-icon" src="assets/icons/icons8-champagne-bottle-24.png" alt="Celebration Icon">
            <h3 class="process-title location-text">Have fun</h3>
            <p class="process-subtitle">Enjoy the Best Night of Your Life</p>
            <p class="process-description">Our beautiful women will arrive and handle all of your entertainment needs for the designated time. All you have to do is sit back and enjoy!</p>
        </div>
        </div>


        <a href="canva.com"><button class="hero-b buttons hero-buttons color-change fade-up">{{home.buttonCTA}}</button></a>


    </div>
</section>


<!-------------TEASE SECTION------------------------>
<section id="flashlight-section">
    <p class="overlay-text-desktop">Hover For a Little Peak</p>
    <p class="overlay-text-mobile">Tap For a Little Peak</p>
  <div class="light"></div>
</section>

<!-------------FINAL CTA SECTION------------------------>
<section class="section">
  <div class="container">
    <h3 class="location-text">This is Scottsdale, <br>You Deserve the Scottsdale Standard</h4>
  </div>
</section>

<!-------------CONTACT SECTION------------------------>
<section class="section" id="contact-section">
    <div class="contact-container">
        <div class="contact-box">            
            <p>Email Us 24/7 at:</p>
            <p>{{home.email}}</p>
            <p>{{home.phoneNumber}}
        </div>
</div>
</section>
<!-------------FAQ SECTION------------------------>
<section id="faq-section">  
    <div class="container">        
<div class="col-md-6 offset-md-3">

                        <div class="faq-title text-center pb-4">
                            <h2>FAQ</h2>
                        </div>
                    </div>
                    <div class="grid-test col-md-10 offset-md-1">
                        <div class="faq" id="accordion">
  <div class="card"> <div class="card-header" id="faqHeading-1"> <div class="mb-0"> <h5 class="faq-title" data-toggle="collapse" data-target="#faqCollapse-1" data-aria-expanded="true" data-aria-controls="faqCollapse-1"> <span class="badge">1</span>{{ home.faqOneQuestion }} </h5> </div> </div> <div id="faqCollapse-1" class="collapse" aria-labelledby="faqHeading-1" data-parent="#accordion"> <div class="card-body"> <p>{{ home.faqOneAnswer }}</p> </div> </div> </div> <div class="card"> <div class="card-header" id="faqHeading-2"> <div class="mb-0"> <h5 class="faq-title" data-toggle="collapse" data-target="#faqCollapse-2" data-aria-expanded="false" data-aria-controls="faqCollapse-2"> <span class="badge">2</span>{{ home.faqTwoQuestion }} </h5> </div> </div> <div id="faqCollapse-2" class="collapse" aria-labelledby="faqHeading-2" data-parent="#accordion"> <div class="card-body"> <p>{{ home.faqTwoAnswer }}</p> </div> </div> </div> <div class="card"> <div class="card-header" id="faqHeading-3"> <div class="mb-0"> <h5 class="faq-title" data-toggle="collapse" data-target="#faqCollapse-3" data-aria-expanded="false" data-aria-controls="faqCollapse-3"> <span class="badge">3</span>{{ home.faqThreeQuestion }} </h5> </div> </div> <div id="faqCollapse-3" class="collapse" aria-labelledby="faqHeading-3" data-parent="#accordion"> <div class="card-body"> <p>{{ home.faqThreeAnswer }}</p> </div> </div> </div> <div class="card"> <div class="card-header" id="faqHeading-4"> <div class="mb-0"> <h5 class="faq-title" data-toggle="collapse" data-target="#faqCollapse-4" data-aria-expanded="false" data-aria-controls="faqCollapse-4"> <span class="badge">4</span>{{ home.faqFourQuestion }} </h5> </div> </div> <div id="faqCollapse-4" class="collapse" aria-labelledby="faqHeading-4" data-parent="#accordion"> <div class="card-body"> <p>{{ home.faqFourAnswer }}</p> </div> </div> </div> <div class="card"> <div class="card-header" id="faqHeading-5"> <div class="mb-0"> <h5 class="faq-title" data-toggle="collapse" data-target="#faqCollapse-5" data-aria-expanded="false" data-aria-controls="faqCollapse-5"> <span class="badge">5</span>{{ home.faqFiveQuestion }} </h5> </div> </div> <div id="faqCollapse-5" class="collapse" aria-labelledby="faqHeading-5" data-parent="#accordion"> <div class="card-body"> <p>{{ home.faqFiveAnswer }}</p> </div> </div> </div> <div class="card"> <div class="card-header" id="faqHeading-6"> <div class="mb-0"> <h5 class="faq-title" data-toggle="collapse" data-target="#faqCollapse-6" data-aria-expanded="false" data-aria-controls="faqCollapse-6"> <span class="badge">6</span>{{ home.faqSixQuestion }} </h5> </div> </div> <div id="faqCollapse-6" class="collapse" aria-labelledby="faqHeading-6" data-parent="#accordion"> <div class="card-body"> <p>{{ home.faqSixAnswer }}</p> </div> </div> </div> <div class="card"> <div class="card-header" id="faqHeading-7"> <div class="mb-0"> <h5 class="faq-title" data-toggle="collapse" data-target="#faqCollapse-7" data-aria-expanded="false" data-aria-controls="faqCollapse-7"> <span class="badge">7</span>{{ home.faqSevenQuestion }} </h5> </div> </div> <div id="faqCollapse-7" class="collapse" aria-labelledby="faqHeading-7" data-parent="#accordion"> <div class="card-body"> <p>{{ home.faqSevenAnswer }}</p> </div> </div> </div> </div>
    </section>
 </main>
